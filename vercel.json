{
  "buildCommand": "npm run build --workspace @cunchao/web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/bootstrap",
      "destination": "/api/bootstrap"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

