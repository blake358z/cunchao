{
  "name": "cunchao-platform",
  "version": "0.1.0",
  "private": true,
  "description": "村超 H5/App/API monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @cunchao/web",
    "dev:api": "npm run dev --workspace @cunchao/api",
    "dev:all": "npm run dev:api & npm run dev",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20"
  }
}

